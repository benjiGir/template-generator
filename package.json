{
  "name": "Template generator",
  "private": true,
  "scripts": {
    "dev": "pnpm --parallel --filter './apps/*' run dev",
    "dev:web": "pnpm --filter @template-generator/web run dev",
    "dev:api": "pnpm --filter @template-generator/api run dev",
    "build": "pnpm --filter @template-generator/shared run build && pnpm --filter @template-generator/component-registry run build && pnpm --filter './apps/*' run build",
    "typecheck": "pnpm -r run typecheck",
    "test": "pnpm --filter @template-generator/shared run test"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@tailwindcss/oxide",
      "esbuild"
    ]
  }
}
